# Base — desarrollo local nativo (ver scripts/dev.sh)
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://dupla:dupla@127.0.0.1:5432/dupla
REDIS_URL=redis://127.0.0.1:6379/0
PROCESSOR_URL=http://localhost:8001
COORDINATION_URL=http://localhost:8002
# Solo development: openssl rand -hex 32 para staging/production
JWT_SECRET=demo-secret-change-in-production-min-32-chars!!
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Motor Dupla (clash detection) — incluido en motor/ dentro del monorepo
# DUPLA_ROOT=/absolute/path/to/dupla-native/motor
# COORDINATION_SMOKE_MODE=true

# Directorios compartidos (scripts/dev.sh los crea bajo var/)
# COORDINATION_OUTPUT_ROOT=/absolute/path/to/dupla-native/var/coord_outputs
# COORDINATION_CACHE_ROOT=/absolute/path/to/dupla-native/var/coord_outputs/aps_cache
# COORDINATION_MAX_WORKERS=6
# COORDINATION_ANALYSIS_PROFILE=fast_compare_aps
# DUPLA_CACHE_DIR=/absolute/path/to/dupla-native/var/cache
# DUPLA_ARTIFACT_DIR=/absolute/path/to/dupla-native/var/artifacts

# Frontend (enlaces en correos)
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# SMTP — restablecimiento de contraseña (requerido en staging/production)
# Ejemplo SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_USER=apikey SMTP_PASSWORD=<API_KEY>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=
EMAIL_FROM_NAME=Dupla
# Solo development + sin SMTP: devuelve el token en la respuesta API (QA local)
# DEV_EXPOSE_RESET_TOKEN=true

# OpenAI (clasificación GA-FO-01 + asistente)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Autodesk APS — OSS + Model Derivative (clasificación enriquecida; opcional)
CLIENT_ID=
CLIENT_SECRET=
APS_BUCKET_NAME=
# Política al crear bucket: transient (recomendado traducción) | persistent
# APS_BUCKET_POLICY=transient
# Vistas SVF2: 2d (rápido) o 2d,3d
# APS_TRANSLATION_VIEWS=2d
# Grace si manifest marca failed (lecturas obsoletas en APS)
# APS_FAILED_MANIFEST_GRACE_POLLS=3
# APS_FAILED_MANIFEST_GRACE_SLEEP_SECONDS=8
# URN nuevo por corrida (timestamp en object key)
# APS_AUTO_UNIQUE_OBJECT_NAME=false
# Región del bucket OSS (US | EMEA | …). Si la cuenta APS es EU y el bucket quedó en US,
# Model Derivative puede fallar con TranslationWorker-InternalFailure / "Tr worker fail to download".
# APS_REGION=US
# APS_DERIVATIVE_MAX_WAIT_SECONDS=600
# APS_DERIVATIVE_POLL_INTERVAL_SECONDS=5
# GA_FO_CLASSIFICATION_CONFIDENCE_MIN=0.55
# GA_FO_APS_CONTEXT_MAX_CHARS=32000

# Geometría 2D real (Plan A): volcado Viewer headless + SVF1 obligatorio
# Requiere Google Chrome en macOS/Linux (PUPPETEER_EXECUTABLE_PATH).
# Primera corrida NASAS09 ~45–50 min; --rerun con caché viewer ~15–40 min.
# COORDINATION_MAX_WORKERS=1 serializa volcados Chrome (evita OOM).
# APS_VIEWER_GEOMETRY_DUMP=true
# APS_VIEWER_GEOMETRY_FORMAT=svf1
# APS_VIEWER_GEOMETRY_TIMEOUT=900
# APS_VIEWER_MAX_VIEWS=4
# APS_VIEWER_MAX_OBJECTS_PER_VIEW=500
# APS_VIEWER_LINE_BUFFER_MM=35
# PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
