# Base — desarrollo local nativo (ver scripts/dev.sh)
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://dupla:dupla@127.0.0.1:5432/dupla
REDIS_URL=redis://127.0.0.1:6379/0
PROCESSOR_URL=http://localhost:8001
COORDINATION_URL=http://localhost:8002
# Solo development: openssl rand -hex 32 para staging/production
JWT_SECRET=demo-secret-change-in-production-min-32-chars!!
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Motor Dupla (clash detection) — incluido en motor/ dentro del monorepo
# DUPLA_ROOT=/absolute/path/to/dupla-native/motor
# COORDINATION_SMOKE_MODE=true

# Directorios compartidos (scripts/dev.sh los crea bajo var/)
# COORDINATION_OUTPUT_ROOT=/absolute/path/to/dupla-native/var/coord_outputs
# COORDINATION_CACHE_ROOT=/absolute/path/to/dupla-native/var/coord_outputs/cad_cache
# COORDINATION_MAX_WORKERS=6
# COORDINATION_ANALYSIS_PROFILE=fast_compare_local
# DUPLA_CACHE_DIR=/absolute/path/to/dupla-native/var/cache
# DUPLA_ARTIFACT_DIR=/absolute/path/to/dupla-native/var/artifacts

# Frontend (enlaces en correos)
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# SMTP — restablecimiento de contraseña (requerido en staging/production)
# Ejemplo SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_USER=apikey SMTP_PASSWORD=<API_KEY>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=
EMAIL_FROM_NAME=Dupla
# Solo development + sin SMTP: devuelve el token en la respuesta API (QA local)
# DEV_EXPOSE_RESET_TOKEN=true

# OpenAI (clasificación GA-FO-01 + asistente)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# GA_FO_CLASSIFICATION_CONFIDENCE_MIN=0.55
# GA_FO_CAD_CONTEXT_MAX_CHARS=32000
