# Vision concurrency / cost
DUPLA_VISION_CONCURRENCY=30
OPENAI_VISION_REASONING_EFFORT=low
OPENAI_VISION_MAX_OUTPUT=4096
OPENAI_VISION_MAX_RETRIES=4
OPENAI_VISION_RETRY_BASE_SECONDS=0.75

# APS cold translation
APS_POLL_INTERVAL_SECONDS=3

# Multi-key rotation (CSV) - applies to Vision AND PartidaGenerator
DUPLA_OPENAI_KEYS=,sk-...,sk-...

# Multi-discipline runs are 4x cost; keep OFF for single-discipline cold runs
DUPLA_ALLOW_MULTI_DISCIPLINE=0
